#!/bin/bash

##############################################################################
# PrintLN - Bash CLI Print Tool (Bash Implementation)
# A lightweight CLI tool for printing documents to network printers
# with an interactive workflow and non-interactive mode
# Version: 3.1.0 - DOCX/Markdown support, older Bash compatibility, bug fixes
##############################################################################

set -euo pipefail

# Color codes for output
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Supported file types
SUPPORTED_TYPES=("pdf" "txt" "md" "markdown" "csv" "docx" "png" "jpeg" "jpg")

# Paper sizes
declare -A PAPER_SIZES=(
  [1]="Letter"
  [2]="Legal"
  [3]="A4"
  [4]="A3"
  [5]="A5"
  [6]="Tabloid"
)

VERSION="3.1.0"
LOG_DIR="${HOME}/println_logs"
TEMP_DIR=""

##############################################################################
# Helper Functions
##############################################################################

# Cleanup function for temp files
cleanup() {
  if [[ -n "$TEMP_DIR" && -d "$TEMP_DIR" ]]; then
    rm -rf "$TEMP_DIR"
  fi
}

trap cleanup EXIT

# Display error message and exit
error() {
  echo -e "${RED}❌ $1${NC}" >&2
  exit 1
}

# Display success message
success() {
  echo -e "${GREEN}✅ $1${NC}"
}

# Display info message
info() {
  echo -e "${BLUE}ℹ️  $1${NC}"
}

# Display warning message
warning() {
  echo -e "${YELLOW}⚠️  $1${NC}"
}

# Initialize logging directory
init_logging() {
  if [[ ! -d "$LOG_DIR" ]]; then
    mkdir -p "$LOG_DIR"
  fi
}

# Log error with timestamp
log_error() {
  local error_msg=$1
  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u +"%Y-%m-%dT%H:%M:%SZ")
  local log_file="${LOG_DIR}/println-error-log.log"
  
  echo "[${timestamp}] ERROR: $error_msg" >> "$log_file"
}

# Get list of available printers
get_printers() {
  if command -v lpstat &> /dev/null; then
    lpstat -p -d 2>/dev/null | grep "printer" | awk '{print $2}' | sed 's/@.*//' | sort
  elif command -v lpadmin &> /dev/null; then
    lpstat -p 2>/dev/null | awk '{print $2}' | sed 's/@.*//'
  else
    return 1
  fi
}

# Normalize file extension
normalize_extension() {
  local ext="$1"
  # Convert to lowercase
  ext=$(echo "$ext" | tr '[:upper:]' '[:lower:]')
  # Handle markdown variants
  if [[ "$ext" == "markdown" ]]; then
    ext="md"
  fi
  echo "$ext"
}

# Validate file exists and has supported type
validate_file() {
  local file_path=$1
  
  if [[ ! -f "$file_path" ]]; then
    error "File not found: $file_path"
  fi
  
  local extension="${file_path##*.}"
  extension=$(normalize_extension "$extension")
  
  local supported=false
  for type in "${SUPPORTED_TYPES[@]}"; do
    type=$(normalize_extension "$type")
    if [[ "$type" == "$extension" ]]; then
      supported=true
      break
    fi
  done
  
  if [[ "$supported" == false ]]; then
    error "Unsupported file type: .${extension}. Supported types: pdf, txt, md, csv, docx, png, jpeg, jpg"
  fi
}

# Check if required tools are available
check_required_tools() {
  local required_tools=("lp" "lpstat")
  local missing_tools=()
  
  for tool in "${required_tools[@]}"; do
    if ! command -v "$tool" &> /dev/null; then
      missing_tools+=("$tool")
    fi
  done
  
  if [[ ${#missing_tools[@]} -gt 0 ]]; then
    error "Missing required tools: ${missing_tools[*]}. Please install CUPS (Common Unix Printing System)."
  fi
}

# Convert DOCX to PDF using available tools
convert_docx_to_pdf() {
  local docx_file=$1
  local pdf_output=${TEMP_DIR}/converted_$(basename "$docx_file" .docx).pdf
  
  if command -v libreoffice &> /dev/null; then
    libreoffice --headless --convert-to pdf --outdir "$TEMP_DIR" "$docx_file" 2>/dev/null || return 1
    mv "${TEMP_DIR}/$(basename "$docx_file" .docx).pdf" "$pdf_output" 2>/dev/null || return 1
  elif command -v soffice &> /dev/null; then
    soffice --headless --convert-to pdf --outdir "$TEMP_DIR" "$docx_file" 2>/dev/null || return 1
    mv "${TEMP_DIR}/$(basename "$docx_file" .docx).pdf" "$pdf_output" 2>/dev/null || return 1
  else
    return 1
  fi
  
  echo "$pdf_output"
}

# Convert Markdown to PDF using available tools
convert_markdown_to_pdf() {
  local md_file=$1
  local pdf_output=${TEMP_DIR}/converted_$(basename "$md_file" .md).pdf
  
  if command -v pandoc &> /dev/null; then
    pandoc "$md_file" -o "$pdf_output" 2>/dev/null || return 1
  elif command -v markdown &> /dev/null; then
    markdown "$md_file" | enscript -B -p "$pdf_output" 2>/dev/null || return 1
  else
    return 1
  fi
  
  echo "$pdf_output"
}

# Convert supported files to PDF if needed
prepare_file_for_printing() {
  local file_path=$1
  local extension
  
  extension=$(normalize_extension "${file_path##*.}")
  
  # Create temp directory if needed
  if [[ -z "$TEMP_DIR" ]]; then
    TEMP_DIR=$(mktemp -d) || error "Failed to create temporary directory"
  fi
  
  case "$extension" in
    docx)
      local converted
      converted=$(convert_docx_to_pdf "$file_path") || error "Failed to convert DOCX to PDF. Ensure LibreOffice is installed."
      echo "$converted"
      ;;
    md|markdown)
      local converted
      converted=$(convert_markdown_to_pdf "$file_path") || error "Failed to convert Markdown to PDF. Ensure pandoc is installed."
      echo "$converted"
      ;;
    *)
      echo "$file_path"
      ;;
  esac
}

# Get file size in KB
get_file_size() {
  local file_path=$1
  local size_bytes
  
  # Try BSD stat first, then GNU stat
  if stat -f "%z" "$file_path" &>/dev/null 2>&1; then
    size_bytes=$(stat -f "%z" "$file_path")
  elif stat -c "%s" "$file_path" &>/dev/null 2>&1; then
    size_bytes=$(stat -c "%s" "$file_path")
  else
    # Fallback using ls (less reliable but works everywhere)
    size_bytes=$(ls -lh "$file_path" | awk '{print $5}')
    echo "$size_bytes"
    return
  fi
  
  # Calculate KB using awk instead of bc for broader compatibility
  awk "BEGIN {printf \"%.2f\", $size_bytes / 1024}"
}

# Show help information
show_help() {
  cat << 'EOF'
PrintLN - Bash CLI Print Tool

Usage:
  println [command] [options]

Commands:
  print              Start interactive print workflow
  print --no-interactive [OPTIONS]  Run print job without interactive prompts
  help, -h, --help   Show this help message
  version, -v, --version  Show version information

Non-Interactive Mode Options:
  Required:
    -p, --printer <name>           Printer name (must be available on system)
    -f, --file <path>              Absolute file path to print

  Optional:
    -c, --color <mode>             Color mode: 'bw' (default) or 'color'
    -d, --duplex <mode>            Duplex mode: 'one-sided', 'long-edge' (default), 'short-edge'
    -n, --copies <number>          Number of copies (default: 1)
    -s, --paper-size <number>      Paper size number (default: 3 for A4):
                                   1=Letter, 2=Legal, 3=A4, 4=A3, 5=A5, 6=Tabloid
    --collate <yes|no>             Collate pages: 'yes' (default) or 'no'
    --both-sides <yes|no>          Print on both sides: 'yes' (default) or 'no'

Examples:
  println print
    # Start interactive workflow

  println print --no-interactive -p "Office_Printer" -f "/home/user/report.pdf" -c color -n 2
    # Print report.pdf in color with 2 copies

  println print --no-interactive -p "HP_LaserJet" -f "/home/user/document.docx" -s 2 --collate no
    # Convert and print DOCX on legal paper without collation

  println print --no-interactive -p "Brother" -f "/home/user/README.md" -d short-edge -n 3
    # Convert Markdown to PDF and print 3 times, double-sided short-edge

  println -v
    # Show version

  println help
    # Show this help message

Supported File Types:
  PDF, TXT, MD (Markdown), CSV, DOCX, PNG, JPEG

Interactive Workflow:
  1. Select printer from available system printers
  2. Enter absolute file path to print
  3. Choose color mode (Black & White or Color)
  4. Select duplex mode (Single-sided, Double-sided long-edge, Double-sided short-edge)
  5. Select paper size (Letter, Legal, A4, A3, A5, Tabloid)
  6. Select collate option (Yes or No)
  7. Select number of copies
  8. Review print job summary
  9. Confirm to submit print job

Note: DOCX files require LibreOffice. Markdown files require pandoc.

For more information, visit: https://github.com/live-by-unix/println
EOF
}

##############################################################################
# Non-Interactive Print Job
##############################################################################

non_interactive_print() {
  local printer=""
  local file_path=""
  local color_mode="bw"
  local duplex_mode="two-sided-long-edge"
  local copies=1
  local paper_size="A4"
  local collate="yes"
  local both_sides="yes"

  # Parse arguments
  while [[ $# -gt 0 ]]; do
    case $1 in
      -p|--printer)
        printer="$2"
        shift 2
        ;;
      -f|--file)
        file_path="$2"
        shift 2
        ;;
      -c|--color)
        if [[ "$2" == "bw" ]] || [[ "$2" == "color" ]]; then
          color_mode="$2"
          shift 2
        else
          error "Invalid color mode: $2. Use 'bw' or 'color'."
        fi
        ;;
      -d|--duplex)
        case "$2" in
          one-sided)
            duplex_mode="one-sided"
            shift 2
            ;;
          long-edge)
            duplex_mode="two-sided-long-edge"
            shift 2
            ;;
          short-edge)
            duplex_mode="two-sided-short-edge"
            shift 2
            ;;
          *)
            error "Invalid duplex mode: $2. Use 'one-sided', 'long-edge', or 'short-edge'."
            ;;
        esac
        ;;
      -n|--copies)
        if ! [[ "$2" =~ ^[0-9]+$ ]] || [ "$2" -lt 1 ]; then
          error "Invalid number of copies: $2. Must be a positive integer."
        fi
        copies="$2"
        shift 2
        ;;
      -s|--paper-size)
        if [[ -z "${PAPER_SIZES[$2]:-}" ]]; then
          error "Invalid paper size number: $2. Valid sizes: 1=Letter, 2=Legal, 3=A4, 4=A3, 5=A5, 6=Tabloid"
        fi
        paper_size="${PAPER_SIZES[$2]}"
        shift 2
        ;;
      --collate)
        if [[ "$2" == "yes" ]] || [[ "$2" == "no" ]]; then
          collate="$2"
          shift 2
        else
          error "Invalid collate option: $2. Use 'yes' or 'no'."
        fi
        ;;
      --both-sides)
        if [[ "$2" == "yes" ]] || [[ "$2" == "no" ]]; then
          both_sides="$2"
          shift 2
        else
          error "Invalid both-sides option: $2. Use 'yes' or 'no'."
        fi
        ;;
      *)
        error "Unknown option: $1"
        ;;
    esac
  done

  # Validate required parameters
  if [[ -z "$printer" ]]; then
    error "Missing required argument: -p, --printer"
  fi
  if [[ -z "$file_path" ]]; then
    error "Missing required argument: -f, --file"
  fi

  # Validate file
  validate_file "$file_path"

  # Verify printer exists
  local printers_list
  if ! printers_list=$(get_printers); then
    error "No printers found on the system. Ensure CUPS is installed and configured."
  fi

  if ! echo "$printers_list" | grep -q "^${printer}$"; then
    error "Printer not found: $printer. Available printers: $(echo "$printers_list" | tr '\n' ', ' | sed 's/,$//')"
  fi

  # Prepare file for printing (convert if needed)
  local print_file
  print_file=$(prepare_file_for_printing "$file_path")

  # Determine duplex mode display
  local duplex_mode_display="Single-sided"
  local duplex_option="one-sided"
  
  if [[ "$duplex_mode" == "two-sided-long-edge" ]]; then
    duplex_mode_display="Double-sided (long-edge)"
    duplex_option="two-sided-long-edge"
  elif [[ "$duplex_mode" == "two-sided-short-edge" ]]; then
    duplex_mode_display="Double-sided (short-edge)"
    duplex_option="two-sided-short-edge"
  fi

  # If both_sides is "no", override to one-sided
  if [[ "$both_sides" == "no" ]]; then
    duplex_option="one-sided"
    duplex_mode_display="Single-sided"
  fi

  # Determine color display
  local color_mode_display="Black & White"
  [[ "$color_mode" == "color" ]] && color_mode_display="Color"

  # Collate display
  local collate_display="Yes"
  [[ "$collate" == "no" ]] && collate_display="No"

  # Get file size
  local file_size
  file_size=$(get_file_size "$file_path")

  # Show summary
  echo ""
  echo "📋 Print Job Summary:"
  echo "$(printf '─%.0s' {1..50})"
  echo "Printer:       $printer"
  echo "File Path:     $file_path"
  echo "File Name:     $(basename "$file_path")"
  echo "File Size:     ${file_size} KB"
  echo "Color Mode:    $color_mode_display"
  echo "Duplex Mode:   $duplex_mode_display"
  echo "Paper Size:    $paper_size"
  echo "Collate:       $collate_display"
  echo "Copies:        $copies"
  echo "$(printf '─%.0s' {1..50})"
  echo ""

  # Submit print job
  info "Submitting print job..."

  local lp_options="-o sides=${duplex_option} -o media=${paper_size}"
  
  if [[ "$color_mode" == "color" ]]; then
    lp_options="${lp_options} -o print-color-mode=color"
  fi

  if [[ "$collate" == "yes" ]]; then
    lp_options="${lp_options} -o collate=true"
  else
    lp_options="${lp_options} -o collate=false"
  fi

  lp_options="${lp_options} -n ${copies}"

  # shellcheck disable=SC2086
  if lp $lp_options -d "$printer" "$print_file" 2>/dev/null; then
    echo ""
    success "Print job submitted successfully!"
    echo "📌 Printer: $printer"
    echo "📄 File: $(basename "$file_path")"
    echo "📋 Copies: $copies"
    echo "🔄 Duplex: $duplex_mode_display"
    echo "📑 Collate: $collate_display"
    echo ""
  else
    local error_msg="Failed to submit print job for file: $(basename "$file_path") to printer: $printer. Duplex: $duplex_mode_display, Copies: $copies, Color: $color_mode_display, Collate: $collate_display"
    log_error "$error_msg"
    error "Failed to submit print job. Check printer status and try again. Error logged to $LOG_DIR"
  fi
}

##############################################################################
# Interactive Print Workflow
##############################################################################

interactive_print() {
  echo ""
  info "Scanning for available printers..."
  echo ""
  
  # Step 1: Get available printers
  local printers_list
  if ! printers_list=$(get_printers); then
    error "No printers found on the system. Ensure CUPS is installed and configured."
  fi
  
  if [[ -z "$printers_list" ]]; then
    error "No printers found on the system."
  fi
  
  # Step 2: Display printers and get selection
  local printer_array=()
  local index=1
  
  while IFS= read -r printer; do
    printer_array+=("$printer")
    echo "  $index. $printer"
    ((index++))
  done <<< "$printers_list"
  
  echo ""
  read -p "Select a printer (enter number): " printer_choice
  
  if ! [[ "$printer_choice" =~ ^[0-9]+$ ]] || [ "$printer_choice" -lt 1 ] || [ "$printer_choice" -gt "${#printer_array[@]}" ]; then
    error "Invalid selection. Please enter a number between 1 and ${#printer_array[@]}"
  fi
  
  local selected_printer="${printer_array[$((printer_choice - 1))]}"
  echo ""
  success "Selected printer: $selected_printer"
  echo ""
  
  # Step 3: Get file path
  read -p "Enter absolute path of file to print: " file_path
  
  if [[ -z "$file_path" ]]; then
    error "File path cannot be empty."
  fi
  
  validate_file "$file_path"
  success "File validated: $(basename "$file_path")"
  echo ""
  
  # Step 4: Get color mode
  echo "Select color mode:"
  echo "  1. Black & White"
  echo "  2. Color"
  echo ""
  read -p "Enter choice (1 or 2): " color_choice
  
  if [[ ! "$color_choice" =~ ^[1-2]$ ]]; then
    error "Invalid selection. Please enter 1 or 2."
  fi
  
  local color_mode="bw"
  local color_mode_display="Black & White"
  if [[ "$color_choice" == "2" ]]; then
    color_mode="color"
    color_mode_display="Color"
  fi
  echo ""
  success "Selected color mode: $color_mode_display"
  echo ""
  
  # Step 5: Get duplex mode
  echo "Select duplex mode:"
  echo "  1. Single-sided"
  echo "  2. Double-sided (long-edge)"
  echo "  3. Double-sided (short-edge)"
  echo ""
  read -p "Enter choice (1, 2, or 3): " duplex_choice
  
  if [[ ! "$duplex_choice" =~ ^[1-3]$ ]]; then
    error "Invalid selection. Please enter 1, 2, or 3."
  fi
  
  local duplex_mode="one-sided"
  local duplex_mode_display="Single-sided"
  if [[ "$duplex_choice" == "2" ]]; then
    duplex_mode="two-sided-long-edge"
    duplex_mode_display="Double-sided (long-edge)"
  elif [[ "$duplex_choice" == "3" ]]; then
    duplex_mode="two-sided-short-edge"
    duplex_mode_display="Double-sided (short-edge)"
  fi
  echo ""
  success "Selected duplex mode: $duplex_mode_display"
  echo ""
  
  # Step 6: Get paper size
  echo "Select paper size:"
  echo "  1. Letter"
  echo "  2. Legal"
  echo "  3. A4"
  echo "  4. A3"
  echo "  5. A5"
  echo "  6. Tabloid"
  echo ""
  read -p "Enter choice (1-6): " paper_size_choice
  
  if [[ ! "$paper_size_choice" =~ ^[1-6]$ ]]; then
    error "Invalid selection. Please enter a number between 1 and 6."
  fi
  
  local paper_size="${PAPER_SIZES[$paper_size_choice]}"
  echo ""
  success "Selected paper size: $paper_size"
  echo ""
  
  # Step 7: Get collate option
  echo "Collate pages?"
  echo "  1. Yes"
  echo "  2. No"
  echo ""
  read -p "Enter choice (1 or 2): " collate_choice
  
  if [[ ! "$collate_choice" =~ ^[1-2]$ ]]; then
    error "Invalid selection. Please enter 1 or 2."
  fi
  
  local collate="yes"
  local collate_display="Yes"
  if [[ "$collate_choice" == "2" ]]; then
    collate="no"
    collate_display="No"
  fi
  echo ""
  success "Selected collate: $collate_display"
  echo ""
  
  # Step 8: Get number of copies (moved before confirmation)
  read -p "Enter number of copies: " copies
  
  if ! [[ "$copies" =~ ^[0-9]+$ ]] || [ "$copies" -lt 1 ]; then
    error "Invalid number of copies. Please enter a positive integer."
  fi
  echo ""
  success "Selected copies: $copies"
  echo ""
  
  # Prepare file for printing (convert if needed)
  local print_file
  print_file=$(prepare_file_for_printing "$file_path")
  
  # Step 9: Show summary
  local file_size
  file_size=$(get_file_size "$file_path")
  
  echo "📋 Print Job Summary:"
  echo "$(printf '─%.0s' {1..50})"
  echo "Printer:       $selected_printer"
  echo "File Path:     $file_path"
  echo "File Name:     $(basename "$file_path")"
  echo "File Size:     ${file_size} KB"
  echo "Color Mode:    $color_mode_display"
  echo "Duplex Mode:   $duplex_mode_display"
  echo "Paper Size:    $paper_size"
  echo "Collate:       $collate_display"
  echo "Copies:        $copies"
  echo "$(printf '─%.0s' {1..50})"
  echo ""
  
  # Step 10: Confirmation
  read -p "Proceed with print job? (y/N): " confirm
  
  if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
    echo ""
    echo -e "${RED}❌ Print job cancelled.${NC}"
    exit 0
  fi
  
  # Step 11: Submit print job (with error handling)
  echo ""
  info "Submitting print job..."
  
  local lp_options="-o sides=${duplex_mode} -o media=${paper_size}"
  
  if [[ "$color_mode" == "color" ]]; then
    lp_options="${lp_options} -o print-color-mode=color"
  fi

  if [[ "$collate" == "yes" ]]; then
    lp_options="${lp_options} -o collate=true"
  else
    lp_options="${lp_options} -o collate=false"
  fi

  lp_options="${lp_options} -n ${copies}"

  # Execute lp command with error handling
  # shellcheck disable=SC2086
  if lp $lp_options -d "$selected_printer" "$print_file" 2>/dev/null; then
    echo ""
    success "Print job submitted successfully!"
    echo "📌 Printer: $selected_printer"
    echo "📄 File: $(basename "$file_path")"
    echo "📋 Copies: $copies"
    echo "🔄 Duplex: $duplex_mode_display"
    echo "📑 Collate: $collate_display"
    echo ""
  else
    local error_msg="Failed to submit print job for file: $(basename "$file_path") to printer: $selected_printer. Duplex: $duplex_mode_display, Copies: $copies, Color: $color_mode_display, Collate: $collate_display"
    log_error "$error_msg"
    error "Failed to submit print job. Check printer status and try again. Error logged to $LOG_DIR"
  fi
}

##############################################################################
# Main Script Logic
##############################################################################

main() {
  init_logging
  check_required_tools
  
  if [[ $# -lt 1 ]]; then
    show_help
    return
  fi

  case "$1" in
    print)
      if [[ $# -gt 1 ]] && [[ "$2" == "--no-interactive" ]]; then
        # Remove 'print' and '--no-interactive' from arguments
        shift 2
        non_interactive_print "$@"
      else
        # Check if any flags are provided
        if [[ $# -gt 1 ]]; then
          error "Unknown option: $2. Did you mean 'print --no-interactive'?"
        fi
        interactive_print
      fi
      ;;
    help|-h|--help)
      show_help
      ;;
    version|-v|--version)
      echo "println v$VERSION"
      ;;
    *)
      error "Unknown command: $1. Use 'println help' for usage information."
      ;;
  esac
}

main "$@"
